---
title: "Blog"
layout: "layouts/base.njk"
description: "Networking, homelab projects, Docker, Juniper, certifications, and technology experiments."
image: "/assets/images/jesus.webp"
---

{% include "components/blog-header.njk" %}

<div style="display: flex; flex-direction: column; gap: 1.5rem;">
{%- for post in collections.blog | reverse -%}
  {%- if not post.data.draft %}
    <div class="panel panel-rack">
      <h3 style="margin-bottom: 0.25rem;">
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </h3>
      <div class="muted" style="font-family: var(--font-mono); font-size: 0.8125rem; margin-bottom: 0.5rem;">
        {{ post.date | readableDate }} &middot; {{ post.templateContent | readingTime }}
      </div>
      {% if post.data.excerpt %}
        <p class="muted" style="margin-bottom: 0.75rem; font-size: 1rem;">{{ post.data.excerpt }}</p>
      {% endif %}
      {% if post.data.tags %}
        <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
          {%- for tag in post.data.tags -%}
            {%- if tag != 'blog' -%}
              <a href="/blog/tag/{{ tag | slugify }}" class="tag">{{ tag }}</a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {% endif %}
    </div>
  {%- endif -%}
{%- endfor -%}
</div>

<script src="/js/blog-search.js" defer></script>
