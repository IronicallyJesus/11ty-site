<header class="site-header">
    <a href="/" class="site-logo">{{ site.author.shortname }}<span>.</span></a>

    <nav class="nav-links">
        <a href="/" class="nav-link{% if page.url == '/' %} active{% endif %}">Home</a>
        <a href="/about" class="nav-link{% if '/about/' in page.url %} active{% endif %}">About</a>
        <a href="/blog" class="nav-link{% if '/blog/' in page.url %} active{% endif %}">Blog</a>
        <a href="/projects" class="nav-link{% if '/projects/' in page.url %} active{% endif %}">Projects</a>
        <a href="/lab" class="nav-link{% if '/lab/' in page.url %} active{% endif %}">Lab</a>
        <a href="/resume" class="btn">Resume</a>
    </nav>

    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
        <i id="theme-toggle-icon" class="fa-solid fa-moon"></i>
    </button>

    <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="Menu">
        <i class="fa-solid fa-bars"></i>
    </button>
</header>

<div id="mobile-menu" class="mobile-menu">
    <a href="/" class="nav-link{% if page.url == '/' %} active{% endif %}">Home</a>
    <a href="/about" class="nav-link{% if '/about/' in page.url %} active{% endif %}">About</a>
    <a href="/blog" class="nav-link{% if '/blog/' in page.url %} active{% endif %}">Blog</a>
    <a href="/projects" class="nav-link{% if '/projects/' in page.url %} active{% endif %}">Projects</a>
    <a href="/lab" class="nav-link{% if '/lab/' in page.url %} active{% endif %}">Lab</a>
    <a href="/resume" class="btn">Resume</a>
</div>
