---
layout: "layouts/base.njk"
---
<article>
    {% if tags and 'blog' in tags %}
    <nav style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> <span style="margin: 0 0.35rem;">/</span>
        <a href="/blog">Blog</a> <span style="margin: 0 0.35rem;">/</span>
        <span style="color: var(--accent);">{{ title }}</span>
    </nav>
    {% endif %}

    <h1>{{ title }}</h1>

    <div class="muted" style="font-family: var(--font-mono); font-size: 0.875rem; margin-bottom: 0.75rem;">
        {{ page.date | readableDate }} &middot; {{ content | readingTime }}
        &middot; <span class="like-btn" data-like-button data-slug="{{ page.fileSlug }}">
            <i class="fa-solid fa-heart"></i>
            <span class="like-count" data-like-count data-slug="{{ page.fileSlug }}">0</span>
        </span>
    </div>

    {% if tags %}
    <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1.5rem;">
        {%- for tag in tags -%}
            {%- if tag != 'blog' -%}
                <a href="/blog/tag/{{ tag | slugify }}" class="tag tag-accent">{{ tag }}</a>
            {%- endif -%}
        {%- endfor -%}
    </div>
    {% endif %}

    {{ content | safe }}
</article>

<script src="/js/likes-handler.js" defer></script>
<script src="/js/prism.js" defer></script>

<div id="bottom"></div>

<script src="/js/mermaid.min.js" defer></script>
<script type="module">
    const renderMermaid = (isLight) => {
        mermaid.initialize({
            startOnLoad: false,
            theme: isLight ? 'default' : 'dark',
            securityLevel: 'loose',
            fontFamily: 'IBM Plex Sans, sans-serif'
        });
        document.querySelectorAll('.mermaid').forEach((el, i) => {
            if (!el.getAttribute('data-original-code')) {
                el.setAttribute('data-original-code', el.textContent.trim());
            }
            el.removeAttribute('data-processed');
            el.innerHTML = el.getAttribute('data-original-code');
            el.id = 'mermaid-diagram-' + i;
        });
        mermaid.run({ nodes: document.querySelectorAll('.mermaid') });
    };
    const isInitialLight = document.body.classList.contains('light-theme');
    renderMermaid(isInitialLight);
    window.addEventListener('theme-changed', (e) => {
        renderMermaid(e.detail.isLight);
    });
</script>
