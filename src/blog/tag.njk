---
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /blog/tag/{{ tag | slugify }}/
layout: layouts/base.njk
description: "Blog posts tagged with '{{ tag }}'"
image: "/assets/images/jesus.webp"
eleventyComputed:
  title: "Tag: {{ tag }}"
---

{% include "components/blog-header.njk" %}

<p class="mb-8 meta-info">
  <a href="/blog" class="hover:text-accent-primary transition-colors">← All posts</a>
</p>

<div class="space-y-8">
{%- for post in collections.blog | reverse -%}
  {%- if post.data.tags and tag in post.data.tags and not post.data.draft -%}
    <div class="card group">
      <h2 class="text-2xl font-bold mb-1">
        <a href="{{ post.url }}" class="card-heading hover:text-accent-primary transition-colors">{{ post.data.title }}</a>
      </h2>
      <div class="accent-primary font-semibold mb-1">
        {{ post.date | readableDate }}
      </div>
      <div class="flex items-center meta-info mb-2">
        <i class="fa-solid fa-clock mr-2" aria-hidden="true"></i>
        <span>{{ post.templateContent | readingTime }}</span>
        <span class="mx-2 separator opacity-40">|</span>
        <i class="fa-solid fa-eye mr-2" aria-hidden="true"></i>
        <span class="view-count" data-view-count data-slug="{{ post.fileSlug }}">...</span>
      </div>
      {% if post.data.excerpt %}
        <p class="article-text mb-3">{{ post.data.excerpt }}</p>
      {% endif %}
      {% if post.data.tags %}
        <div class="flex flex-wrap gap-2">
          {%- for t in post.data.tags -%}
            {%- if t != 'blog' -%}
              <a href="/blog/tag/{{ t | slugify }}" class="inline-block text-xs font-medium py-1 px-2.5 rounded-full border border-accent-primary/30 text-accent-primary hover:bg-accent-primary/10 transition-colors">{{ t }}</a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {% endif %}
    </div>
  {%- endif -%}
{%- endfor -%}
</div>
